<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#1A0840"/>
      <stop offset="100%" stop-color="#0A0118"/>
    </radialGradient>
    <linearGradient id="bolt" x1="20%" y1="0%" x2="80%" y2="100%">
      <stop offset="0%" stop-color="#C084FC"/>
      <stop offset="50%" stop-color="#A855F7"/>
      <stop offset="100%" stop-color="#00D4FF"/>
    </linearGradient>
    <filter id="glow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="12" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <!-- Dark rounded background -->
  <rect width="512" height="512" rx="110" ry="110" fill="url(#bg)"/>
  <!-- Subtle outer glow ring -->
  <rect width="512" height="512" rx="110" ry="110" fill="none"
        stroke="rgba(168,85,247,0.3)" stroke-width="6"/>
  <!-- Lightning bolt -->
  <polygon
    points="295,48 128,295 248,295 215,464 384,205 258,205 310,48"
    fill="url(#bolt)"
    filter="url(#glow)"
    stroke="rgba(255,255,255,0.15)"
    stroke-width="3"
    stroke-linejoin="round"/>
</svg>
